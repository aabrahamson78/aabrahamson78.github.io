        function renderCharts(regs, fullTotals) {
            // Aggregate sample metrics for global charts
            const ownRentMap = regs.reduce((acc, r) => {
                const key = r.ownRent || 'Unknown';
                acc[key] = (acc[key] || 0) + 1;
                return acc;
            }, {});

            let sampleHaTotal = 0, sampleOnaTotal = 0, sampleTotalApproved = 0;
            regs.forEach(r => {
                sampleHaTotal += (r.haAmount || 0);
                sampleOnaTotal += (r.onaAmount || 0);
                sampleTotalApproved += (r.ihpAmount || 0);
            });

            // Calculate Scaling Factors
            const countScale = fullTotals.totalValidRegistrations / (regs.length || 1);
            const amountScale = fullTotals.ihpAmount / (sampleTotalApproved || 1);

            // 1. Homeowners vs Renters (Scaled)
            if (ownRentChart) ownRentChart.destroy();
            const orCtx = document.getElementById('ownRentChart').getContext('2d');
            ownRentChart = new Chart(orCtx, {
                type: 'bar',
                data: {
                    labels: Object.keys(ownRentMap).map(k => k === 'O' ? 'Owners' : (k === 'R' ? 'Renters' : k)),
                    datasets: [{
                        label: 'Applicants (Estimated)',
                        data: Object.values(ownRentMap).map(v => Math.round(v * countScale)),
                        backgroundColor: '#38bdf8',
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } },
                        x: { grid: { display: false }, ticks: { color: '#94a3b8' } }
                    }
                }
            });

            // 2. Assistance Type Distribution (Scaled)
            if (assistanceChart) assistanceChart.destroy();
            const aCtx = document.getElementById('assistanceChart').getContext('2d');
            assistanceChart = new Chart(aCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Housing Assistance (Est)', 'Other Needs (Est)'],
                    datasets: [{
                        data: [sampleHaTotal * amountScale, sampleOnaTotal * amountScale],
                        backgroundColor: ['#818cf8', '#fb7185'],
                        borderWidth: 0,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom', labels: { color: '#94a3b8', padding: 20 } } }
                }
            });

            // NEW: Socioeconomic Analysis
            renderSocioeconomicVisuals(regs, fullTotals);
        }

        // ---------------- Filter Logic ----------------

        function initFilters() {
            const yearSelect = document.getElementById('yearFilter');
            const currentYear = new Date().getFullYear();
            for (let y = currentYear; y >= 2000; y--) {
                const opt = document.createElement('option');
                opt.value = y;
                opt.textContent = y;
                yearSelect.appendChild(opt);
            }

            const stateSelect = document.getElementById('stateFilter');
            const states = ["AL", "AK", "AS", "AZ", "AR", "CA", "CO", "CT", "DE", "DC", "FL", "GA", "GU", "HI", "ID", "IL", "IN", "IA", "KS", "KY", "LA", "ME", "MD", "MA", "MI", "MN", "MS", "MO", "MT", "NE", "NV", "NH", "NJ", "NM", "NY", "NC", "ND", "MP", "OH", "OK", "OR", "PA", "PR", "RI", "SC", "SD", "TN", "TX", "UT", "VT", "VI", "VA", "WA", "WV", "WI", "WY"];
            states.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s;
                opt.textContent = s;
                stateSelect.appendChild(opt);
            });

            // Listeners
            [yearSelect, stateSelect, document.getElementById('countyFilter')].forEach(el => {
                el.addEventListener('change', () => fetchDisasters());
            });

            stateSelect.addEventListener('change', (e) => populateCounties(e.target.value));
        }

        async function populateCounties(state) {
            const countySelect = document.getElementById('countyFilter');
            countySelect.innerHTML = '<option value="">All Counties</option>';
            if (!state) {
                countySelect.disabled = true;
                return;
            }

            countySelect.disabled = false;
            try {
                const resp = await fetch(`${API_BASE}/DisasterDeclarationsSummaries?$filter=state eq '${state}' and ihProgramDeclared eq true&$select=designatedArea&$top=500`);
                const data = await resp.json();
                const areas = data.DisasterDeclarationsSummaries || [];

                const uniqueCounties = [...new Set(areas.map(a => a.designatedArea))].sort();
                uniqueCounties.forEach(c => {
                    const opt = document.createElement('option');
                    opt.value = c;
                    opt.textContent = c;
                    if (c) countySelect.appendChild(opt);
                });
            } catch (err) {
                console.error("County load error:", err);
            }
        }

        // Search Handlers
        let searchTimeout;
        document.getElementById('searchInput').addEventListener('input', (e) => {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                fetchDisasters();
            }, 400);
        });

        // ---------------- Helpers ----------------

        function formatCurrency(val) {
            return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);
        }

        // Initial Load
        initFilters();
        fetchDisasters();
    </script>
</body>

