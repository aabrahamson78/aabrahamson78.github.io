                data[g].ownerCount = Math.round(data[g].ownerCount * countScale);
                data[g].renterCount = Math.round(data[g].renterCount * countScale);

                data[g].ihpAmount = data[g].ihpAmount * amountScale;
                data[g].haAmount = data[g].haAmount * amountScale;
                data[g].onaAmount = data[g].onaAmount * amountScale;
                data[g].rentalAmount = data[g].rentalAmount * amountScale;
                data[g].repairAmount = data[g].repairAmount * amountScale;
                data[g].personalPropertyAmount = data[g].personalPropertyAmount * amountScale;
