        async function renderCountyMap(stateAbbr, summaries) {
            document.getElementById('mapLoaderBadge').classList.remove('hidden');
            document.getElementById('mapLegend').classList.add('hidden');

            // Build county -> amount lookup from summaries (county field may be like "Lee (County)" or "Lee")
            const countyAmounts = {};
            summaries.forEach(s => {
                if (!s.county) return;
                const key = s.county
                    .replace(/\s*\(County\)$/i, '')
                    .replace(/\s+County$/i, '')
                    .replace(/\s+Parish$/i, '')
                    .replace(/\s+Borough$/i, '')
                    .replace(/\s+Census Area$/i, '')
                    .trim()
                    .toLowerCase();
                countyAmounts[key] = (countyAmounts[key] || 0) + (s.ihpAmount || 0);
            });

            const maxAmount = Math.max(...Object.values(countyAmounts), 1);

            // Load TopoJSON (cached)
            if (!countyTopoCache) {
                const resp = await fetch('https://cdn.jsdelivr.net/npm/us-atlas@3/counties-10m.json');
                countyTopoCache = await resp.json();
            }

            // Convert to GeoJSON and filter to disaster state
            const stateNameMap = {
                AL: 'Alabama', AK: 'Alaska', AZ: 'Arizona', AR: 'Arkansas', CA: 'California', CO: 'Colorado', CT: 'Connecticut',
                DE: 'Delaware', FL: 'Florida', GA: 'Georgia', HI: 'Hawaii', ID: 'Idaho', IL: 'Illinois', IN: 'Indiana',
                IA: 'Iowa', KS: 'Kansas', KY: 'Kentucky', LA: 'Louisiana', ME: 'Maine', MD: 'Maryland', MA: 'Massachusetts',
                MI: 'Michigan', MN: 'Minnesota', MS: 'Mississippi', MO: 'Missouri', MT: 'Montana', NE: 'Nebraska',
                NV: 'Nevada', NH: 'New Hampshire', NJ: 'New Jersey', NM: 'New Mexico', NY: 'New York', NC: 'North Carolina',
                ND: 'North Dakota', OH: 'Ohio', OK: 'Oklahoma', OR: 'Oregon', PA: 'Pennsylvania', RI: 'Rhode Island',
                SC: 'South Carolina', SD: 'South Dakota', TN: 'Tennessee', TX: 'Texas', UT: 'Utah', VT: 'Vermont',
                VA: 'Virginia', WA: 'Washington', WV: 'West Virginia', WI: 'Wisconsin', WY: 'Wyoming',
                DC: 'District of Columbia', PR: 'Puerto Rico', GU: 'Guam', VI: 'Virgin Islands',
                AS: 'American Samoa', MP: 'Northern Mariana Islands'
            };

            // State FIPS map
            const stateFipsMap = {
                AL: '01', AK: '02', AZ: '04', AR: '05', CA: '06', CO: '08', CT: '09', DE: '10', DC: '11', FL: '12',
                GA: '13', HI: '15', ID: '16', IL: '17', IN: '18', IA: '19', KS: '20', KY: '21', LA: '22', ME: '23',
                MD: '24', MA: '25', MI: '26', MN: '27', MS: '28', MO: '29', MT: '30', NE: '31', NV: '32', NH: '33',
                NJ: '34', NM: '35', NY: '36', NC: '37', ND: '38', OH: '39', OK: '40', OR: '41', PA: '42', RI: '44',
                SC: '45', SD: '46', TN: '47', TX: '48', UT: '49', VT: '50', VA: '51', WA: '53', WV: '54', WI: '55',
                WY: '56', PR: '72', GU: '66', VI: '78', AS: '60', MP: '69'
            };

            const stateFips = stateFipsMap[stateAbbr];
            const allCounties = topojson.feature(countyTopoCache, countyTopoCache.objects.counties);
            const stateCounties = stateFips
                ? { type: 'FeatureCollection', features: allCounties.features.filter(f => f.id.toString().startsWith(stateFips)) }
                : allCounties;

            function getColor(amount) {
                const t = Math.pow(amount / maxAmount, 0.5); // sqrt scale for better spread
                const r = Math.round(219 + (0 - 219) * t);
                const g = Math.round(234 + (68 - 234) * t);
                const b = Math.round(254 + (181 - 254) * t);
                return `rgb(${r},${g},${b})`;
            }

            function styleFeature(feature) {
                const name = (feature.properties.name || '').toLowerCase();
                const amount = countyAmounts[name] || 0;
                return {
                    fillColor: amount > 0 ? getColor(amount) : '#f1f3f5',
                    weight: 0.8,
                    color: '#dee2e6',
                    fillOpacity: 0.9
                };
            }

            // Initialise or reuse map
            if (!countyMap) {
                countyMap = L.map('countyMap', { zoomControl: true, attributionControl: false });
                L.tileLayer('https://{s}.basemaps.cartocdn.com/light_nolabels/{z}/{x}/{y}{r}.png', {
                    subdomains: 'abcd', maxZoom: 19
                }).addTo(countyMap);
            }

            if (countyLayer) {
                countyMap.removeLayer(countyLayer);
            }

            countyLayer = L.geoJSON(stateCounties, {
                style: styleFeature,
                onEachFeature(feature, layer) {
                    const name = (feature.properties.name || '').toLowerCase();
                    const amount = countyAmounts[name] || 0;
                    layer.bindTooltip(
                        `<div style="font-family:'Inter',sans-serif;font-size:12px;">
                            <strong>${feature.properties.name} County</strong><br/>
                            ${amount > 0 ? formatCurrency(amount) : 'No data'}
                        </div>`,
                        { sticky: true, className: 'county-tooltip' }
                    );
                    layer.on({
                        mouseover(e) { e.target.setStyle({ weight: 2, color: '#0044B5', fillOpacity: 1 }); },
                        mouseout(e) { countyLayer.resetStyle(e.target); }
                    });
                }
            }).addTo(countyMap);

            countyMap.fitBounds(countyLayer.getBounds(), { padding: [20, 20] });

            // Legend
            document.getElementById('mapLegendMax').innerText = formatCurrency(maxAmount);
            document.getElementById('mapLegend').classList.remove('hidden');
            document.getElementById('mapLoaderBadge').classList.add('hidden');
        }

        function renderSocioeconomicVisuals(regs, fullTotals) {
            // Initialize data structure
            const groups = ['Above ALICE', 'ALICE', 'Poverty'];
            const data = groups.reduce((acc, g) => {
                acc[g] = {
                    total: 0,
                    approved: 0,
                    denied: 0,
                    ihpAmount: 0,
                    haAmount: 0,
                    onaAmount: 0,
                    rentalAmount: 0,
                    repairAmount: 0,
                    replacementAmount: 0,
                    personalPropertyAmount: 0,
                    rentalCount: 0,
                    repairCount: 0,
                    propCount: 0,
                    otherCount: 0,
                    ownerAmount: 0,
                    renterAmount: 0,
                    ownerCount: 0,
                    renterCount: 0
                };
                return acc;
            }, {});

            // 1. Calculate sample metrics
            let sampleTotalApproved = 0;
            regs.forEach(r => {
                const g = getALICECategory(r);
                data[g].total++;
                if (r.ihpEligible || r.ihpAmount > 0) {
                    data[g].approved++;
                } else {
                    data[g].denied++;
                }
                data[g].ihpAmount += (r.ihpAmount || 0);
                sampleTotalApproved += (r.ihpAmount || 0);

                data[g].haAmount += (r.haAmount || 0);
                data[g].onaAmount += (r.onaAmount || 0);

                if (r.rentalAssistanceAmount > 0) {
                    data[g].rentalAmount += r.rentalAssistanceAmount;
                    data[g].rentalCount++;
                }
                if (r.repairAmount > 0) {
                    data[g].repairAmount += r.repairAmount;
                    data[g].repairCount++;
                }
                if (r.personalPropertyAmount > 0) {
                    data[g].personalPropertyAmount += r.personalPropertyAmount;
                    data[g].propCount++;
                }
                if (r.onaAmount > 0) {
                    data[g].otherCount++;
                }

                data[g].replacementAmount += (r.replacementAmount || 0);

                if (r.ownRent === 'O') {
                    data[g].ownerAmount += (r.ihpAmount || 0);
                    data[g].ownerCount++;
                } else if (r.ownRent === 'R') {
                    data[g].renterAmount += (r.ihpAmount || 0);
                    data[g].renterCount++;
                }
            });

            // 2. Calculate Scaling Factors
            const countScale = fullTotals.totalValidRegistrations / (regs.length || 1);
            const amountScale = fullTotals.ihpAmount / (sampleTotalApproved || 1);

            // 3. Apply scaling
            groups.forEach(g => {
                data[g].total = Math.round(data[g].total * countScale);
                data[g].approved = Math.round(data[g].approved * countScale);
                data[g].denied = Math.round(data[g].denied * countScale);
                data[g].rentalCount = Math.round(data[g].rentalCount * countScale);
                data[g].repairCount = Math.round(data[g].repairCount * countScale);
